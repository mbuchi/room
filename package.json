{
  "name": "room",
  "private": true,
  "version": "0.9.0",
  "type": "module",
  "description": "room — Swiss zoning density explorer: how densely built is this zone, and where does your parcel sit on the distribution?",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mbuchi/room.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@aireon/shared": "github:mbuchi/aireon-shared#v1.36.3",
