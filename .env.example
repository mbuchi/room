# Client-side variables (exposed to the browser via Vite)

# Signal collection endpoint.
# Default: the client calls the relative path /api/signal-collect, served by
# api/signal-collect.ts as a Vercel Edge Function.
# Override the endpoint explicitly with:
# VITE_SIGNAL_COLLECT_URL=https://example.com/api/signal-collect

# Server-side variables (configured in Vercel Project Settings → Environment Variables)
# Both are optional and forwarded by the /api/signal-collect Edge Function.
# SIGNAL_COLLECT_API_URL=https://res.zeroo.ch/res_api/signal/collect
# SIGNAL_COLLECT_API_TOKEN=your-bearer-token-without-the-Bearer-prefix

# Mapbox publishable client token (pk.*). Get yours at https://account.mapbox.com/.
# Restrict the token to your deploy domain(s) in the Mapbox console.
VITE_MAPBOX_TOKEN=pk.your-mapbox-public-token

# Gemini API key for the @swissnovo/shared ClaireAssistant.
VITE_GEMINI_API_KEY=your-gemini-api-key

# Zitadel OIDC sign-in (required for the user menu and screenshot saving).
# Create an application in Zitadel (PKCE/SPA), then fill in the values below.
VITE_ZITADEL_AUTHORITY=https://your-instance.zitadel.cloud
VITE_ZITADEL_CLIENT_ID=your-zitadel-client-id
